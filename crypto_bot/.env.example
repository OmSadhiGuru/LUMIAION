# Copy this file to crypto_bot/.env and fill in your own values.
# NEVER commit your real .env file - it is already in .gitignore.

# --- Safety switch ---------------------------------------------------------
# Must be explicitly "true" for the bot to place real orders. If false (or
# if an exchange has no API keys below), that exchange runs in dry-run
# (simulated) mode: signals/arbitrage are still scanned and logged/notified,
# but no real orders are sent.
ENABLE_LIVE_TRADING=false

# --- Exchange API credentials (ccxt) ---------------------------------------
# Leave blank to use an exchange for market data / arbitrage scanning only.
KRAKEN_API_KEY=
KRAKEN_API_SECRET=
KRAKEN_ENABLED=true

COINBASE_API_KEY=
COINBASE_API_SECRET=
COINBASE_PASSWORD=
COINBASE_ENABLED=true

KUCOIN_API_KEY=
KUCOIN_API_SECRET=
KUCOIN_PASSWORD=
KUCOIN_ENABLED=true

BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_ENABLED=true

# --- Trading universe -------------------------------------------------------
# Comma-separated list of ccxt symbols. Mix high-market-value (BTC/ETH) and
# lower-market-value altcoins to surface wider arbitrage spreads.
TRADING_PAIRS=BTC/USDT,ETH/USDT,SOL/USDT,ARB/USDT,INJ/USDT

# --- Risk management (all percentages) -------------------------------------
MAX_RISK_PER_TRADE_PCT=1.0
MAX_POSITION_PCT=20.0
MAX_OPEN_POSITIONS=5
MAX_DAILY_LOSS_PCT=5.0
DEFAULT_STOP_LOSS_PCT=2.0
DEFAULT_TAKE_PROFIT_PCT=4.0
MIN_RISK_REWARD_RATIO=1.5
STARTING_EQUITY=10000

# --- Arbitrage scanner -------------------------------------------------------
ARBITRAGE_MIN_SPREAD_PCT=0.5
TAKER_FEE_PCT=0.1
ARBITRAGE_MAX_POSITION_USD=500

# --- Fair Value Gap / signal engine -----------------------------------------
FVG_TIMEFRAMES_SHORT=15m,1h
FVG_TIMEFRAMES_LONG=4h,1d
FVG_MIN_GAP_PCT=0.05
FVG_LOOKBACK_CANDLES=200

# --- General -----------------------------------------------------------------
POLL_INTERVAL_SECONDS=60
CRYPTO_BOT_DB_PATH=crypto_bot/data/trades.db

# --- Telegram notifications (reuses the LUMIAION bot) -----------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
